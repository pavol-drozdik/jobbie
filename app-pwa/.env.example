# Nest API (must be running for login and /app). Browser calls :8000 directly; auth uses Bearer + BFF cookies when same-site.
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Public marketing origin for canonical URLs, OG tags, and sitemap (no trailing slash), e.g. https://jobbie.sk
NUXT_PUBLIC_SITE_URL=
# Set to 1 on production marketing host only — enables indexing, public SSR routes, sitemap, and allow robots
NUXT_PUBLIC_ALLOW_INDEXING=
# Set to 1 after legal counsel review — terms/privacy become indexable and appear in sitemap
NUXT_PUBLIC_LEGAL_PUBLISHED=
# Optional brand / contact overrides for SEO schema and trust UI
NUXT_PUBLIC_BRAND_NAME=JOBBIE
NUXT_PUBLIC_BRAND_ALTERNATE_NAME=Jobbie
NUXT_PUBLIC_SUPPORT_EMAIL=info@jobbie.sk
NUXT_PUBLIC_SUPPORT_PHONE=
NUXT_PUBLIC_SOCIAL_INSTAGRAM_URL=
NUXT_PUBLIC_SOCIAL_FACEBOOK_URL=
# Production SEO (set only on public apex): canonical origin + allow indexing
# NUXT_PUBLIC_SITE_URL=https://jobbie.sk
# NUXT_PUBLIC_ALLOW_INDEXING=1
# Optional: CDN origin for static `_nuxt` assets (CloudFront, R2 public URL, etc.)
NUXT_PUBLIC_CDN_URL=
# Optional: image CDN/transform proxy prefix for public Supabase URLs (list thumbnails)
NUXT_PUBLIC_MEDIA_CDN_URL=
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_ANON_KEY=
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NUXT_PUBLIC_TURNSTILE_SITE_KEY=
# Core Web Vitals RUM: sample rate 0..1 (see plugins/web-vitals.client.ts)
NUXT_PUBLIC_WEB_VITALS_SAMPLE_RATE=0.1

# Client audit telemetry: 1 = send sampled nav/click batches to API
NUXT_PUBLIC_AUDIT_CLIENT_EVENTS=
# Sample rate 0..1 when audit enabled (default 0.4)
NUXT_PUBLIC_AUDIT_CLIENT_SAMPLE_RATE=

# Sentry (browser). Empty = off
NUXT_PUBLIC_SENTRY_DSN=
NUXT_PUBLIC_SENTRY_ENVIRONMENT=development
NUXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0

# PostHog. Empty = off. Default EU host.
NUXT_PUBLIC_POSTHOG_KEY=
NUXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Optional: config / defaults version string (PostHog dashboard / wizard)
NUXT_PUBLIC_POSTHOG_DEFAULTS=
# Google Tag Manager (GTM-…). GA4 + Clarity are configured in the container. Consent-gated.
NUXT_PUBLIC_GTM_CONTAINER_ID=
