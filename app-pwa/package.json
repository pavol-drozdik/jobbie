{
  "name": "jobbie-app-pwa",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "nuxt prepare",
    "build": "node --max-old-space-size=8192 ./node_modules/nuxt/bin/nuxt.mjs build",
    "build:cloudflare": "node ./scripts/nuxt-build-cloudflare.mjs",
    "build:analyze": "node ./scripts/build-analyze.mjs",
    "ci:win": "node ./scripts/win-clean-stale-native-bins.mjs && npm ci",
    "ci:win:quarantine": "node ./scripts/win-clean-stale-native-bins.mjs --quarantine-node-modules && npm ci",
    "clean:win-native": "node ./scripts/win-clean-stale-native-bins.mjs",
    "dev": "node --max-old-space-size=8192 ./node_modules/nuxt/bin/nuxt.mjs dev",
    "generate": "node --max-old-space-size=8192 ./node_modules/nuxt/bin/nuxt.mjs generate",
    "preview": "nuxt preview",
    "cap:sync": "nuxt generate && npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "icons:generate": "node ./scripts/generate-pwa-icons.mjs",
    "thumbs:generate": "node ./scripts/generate-default-thumb.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:prod": "npm audit --omit=dev"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fortawesome/fontawesome-free": "^6.5.0",
    "@nuxt/image": "^2.0.0",
    "@sentry/vue": "^10.51.0",
    "@stripe/stripe-js": "^9.7.0",
    "@supabase/supabase-js": "^2.105.1",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@tiptap/vue-3": "^3.22.5",
    "chart.js": "^4.4.1",
    "isomorphic-dompurify": "^3.3.0",
    "nuxt": "^3.14.0",
    "pdfjs-dist": "^4.10.38",
    "posthog-js": "^1.372.6",
    "socket.io-client": "^4.7.0",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@nuxtjs/tailwindcss": "^6.12.0",
    "@vite-pwa/nuxt": "^0.10.0",
    "rollup-plugin-visualizer": "^6.0.11",
    "typescript": "^5.0.0",
    "unstorage": "^1.17.4",
    "vitest": "^4.1.8",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1"
  },
  "overrides": {
    "tar": "^7.5.16",
    "esbuild": ">=0.28.1",
    "shell-quote": ">=1.8.4"
  }
}
