# Copy to /etc/nestjs-typesense/backup.env on the VPS and chmod 600.
# Never commit the real file.

TYPESENSE_URL=http://127.0.0.1:8108
TYPESENSE_API_KEY=replace_with_same_typesense_admin_key
TYPESENSE_DATA_DIR=/srv/nestjs-typesense/data/typesense
TYPESENSE_SNAPSHOT_HOST_ROOT=/srv/nestjs-typesense/data/typesense-snapshots
TYPESENSE_SNAPSHOT_CONTAINER_ROOT=/snapshots

COMPOSE_FILE=/srv/nestjs-typesense/docker-compose.yml
COMPOSE_PROJECT_DIR=/srv/nestjs-typesense

R2_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace_with_bucket_scoped_r2_access_key_id
R2_SECRET_ACCESS_KEY=replace_with_bucket_scoped_r2_secret_access_key
R2_BUCKET=replace_with_private_backup_bucket_name
R2_TYPESENSE_PREFIX=typesense/
R2_SUPABASE_PREFIX=supabase/

# Public recipient is safe to store on the VPS. Keep the private identity offline.
AGE_RECIPIENT=age1replace_with_public_recipient

# Set only during restore, then remove from the VPS after recovery.
AGE_IDENTITY_FILE=

# Optional logical Supabase Postgres dump. Leave empty to skip.
SUPABASE_DB_URL=
SUPABASE_CLI=supabase

MAX_DISK_USED_PERCENT=80
