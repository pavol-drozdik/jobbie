# JOBBIE NestJS backend production env. Place real values in .env.backend on the VPS only.
NODE_ENV=production
PORT=8000

PUBLIC_API_URL=https://api.example.com
PUBLIC_APP_URL=https://jobbie.sk
PUBLIC_APP_ORIGIN=https://jobbie.sk
CORS_ORIGINS=https://jobbie.sk

SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_READ_URL=

TYPESENSE_PROTOCOL=http
TYPESENSE_HOST=typesense
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=replace_with_same_typesense_admin_key_as_compose_env
TYPESENSE_COLLECTION_JOBS=jobs
TYPESENSE_COLLECTION_PROFILES=profiles
TYPESENSE_COLLECTION_SCHOOLS=sk_schools
TYPESENSE_SCHOOLS_NUM_TYPOS=2
TYPESENSE_JOBS_EMBED_MODEL=ts/all-MiniLM-L12-v2
TYPESENSE_JOBS_NUM_TYPOS=1
TYPESENSE_JOBS_DROP_TOKENS_THRESHOLD=0
SEARCH_REINDEX_CONCURRENCY=8

REDIS_URL=
REQUIRE_REDIS_IN_PRODUCTION=0

STRIPE_PUBLISHABLE_KEY=replace_with_stripe_publishable_key
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret
STRIPE_PRODUCT_ID_CREDITS=prod_credits_default
STRIPE_PRICE_ID_CREDITS=price_credits_default
STRIPE_CREDITS_PER_PACK=10

TURNSTILE_SECRET_KEY=
CHAT_CONTENT_ENCRYPTION_KEY=replace_with_base64_32_byte_key
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Jobbie <noreply@example.com>

SEARCH_ANALYTICS_SECRET=replace_with_long_random_secret
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
METRICS_BEARER_TOKEN=replace_with_long_random_metrics_token
AUDIT_CHAIN_SECRET=replace_with_long_random_audit_secret
AUDIT_API_SAMPLE_RATE=0.02
AUDIT_RETENTION_TELEMETRY_DAYS=90
AUDIT_RETENTION_FINANCIAL_YEARS=7
ENGAGEMENT_RETENTION_DAYS=90

SESSION_ACCESS_TTL_SECONDS=3600
SESSION_REFRESH_TTL_DAYS=30
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ALLOW_HS256=false
SUPABASE_JWT_SECRET=
DEBUG_SUPABASE_PROJECT_SECRET=replace_with_long_random_debug_secret

CLAMAV_HOST=
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=10000
CLAMAV_MAX_BYTES=26214400
CLAMAV_FAIL_OPEN=false

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@example.com

NOTIFICATION_PREFERENCE_TOKEN_SECRET=replace_with_long_random_secret
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PRICING_INQUIRY_TO=support@example.com
