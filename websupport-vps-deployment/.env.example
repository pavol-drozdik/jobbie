# Public DNS name for this API, for example api.example.com.
APP_DOMAIN=api.example.com

# Use a versioned GHCR tag in production. Do not deploy latest as the only tag.
BACKEND_IMAGE=ghcr.io/GITHUB_USERNAME/jobbie-backend:VERSION

# Nest API replicas on this VPS (default 1). Requires REDIS_URL in .env.backend when > 1.
# See docs/staging-production-manual.md §17 — Scale Nest API on one VPS.
# BACKEND_SCALE=2

# Automatic scale on this VPS (jobbie-backend-autoscale.timer). Off by default.
# BACKEND_AUTOSCALE_ENABLED=1
# Optional tuning (defaults work for most VPS sizes):
# AUTOSCALE_RESERVE_RAM_MB=2800
# AUTOSCALE_PER_REPLICA_RAM_MB=1024
# AUTOSCALE_RESERVE_CPU=1.5
# AUTOSCALE_UP_CPU_PCT=70
# AUTOSCALE_DOWN_CPU_PCT=35
# AUTOSCALE_UP_LATENCY_MS=800
# AUTOSCALE_DOWN_LATENCY_MS=250
# AUTOSCALE_COOLDOWN_SEC=900

# Generate with: openssl rand -hex 32
# Must match TYPESENSE_API_KEY in .env.backend and /etc/nestjs-typesense/backup.env.
TYPESENSE_API_KEY=replace_with_long_random_typesense_admin_key
