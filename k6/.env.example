# Copy to `k6/.env` (gitignored via root `.env`) and fill in real values.
# Run: k6 run --env-file k6/.env k6/backend-smoke.js

# Nest API origin (no trailing slash). Same as PWA NUXT_PUBLIC_API_BASE_URL
# without `/api` suffix, e.g. https://your-service.up.railway.app
BASE_URL=http://localhost:8000

# Nuxt app origin for frontend-smoke.js
FRONTEND_URL=http://localhost:3001

# Supabase access_token (JWT) for authenticated scripts — short-lived; rotate after tests
API_JWT=

# Chat stress: room UUID from the app URL /chat/[roomId]
CHAT_ROOM_ID=

# Optional: pin a job id for GET /api/jobs/:id when latest list is empty
# SAMPLE_JOB_ID=

# --- Optional: tune “human-like” delays (backend-stress / sustained / flat-75 use these) ---
# K6_START_JITTER_MAX_SEC=40
# K6_THINK_AFTER_DETAIL_MIN_SEC=12
# K6_THINK_AFTER_DETAIL_MAX_SEC=28
# K6_THINK_END_MIN_SEC=20
# K6_THINK_END_MAX_SEC=50

# --- Optional: pause between chat iterations ---
# K6_CHAT_THINK_MIN_SEC=8
# K6_CHAT_THINK_MAX_SEC=24
