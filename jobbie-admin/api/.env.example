# Admin desktop API (local only — bind 127.0.0.1)
ADMIN_API_PORT=3099

# Step-up window for @RequireRecentLogin() (JWT auth_time / iat). Default 120 min.
# Main public API (backend-ts) stays at 15 min — this env applies to jobbie-admin only.
ADMIN_RECENT_LOGIN_MINUTES=120

# Local dev: grant all admin scopes when app_role=admin (ignores profiles.admin_role analyst)
# ADMIN_DEV_FULL_SCOPES=1

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Optional: read replica
# SUPABASE_READ_URL=

# Tamper-evident audit chain (required in production)
AUDIT_CHAIN_SECRET=

# Optional: only for main API GET /search/analytics/summary (external tools).
# Admin desktop reads search_query_logs via service_role — no secret required for Analytics UI.
SEARCH_ANALYTICS_SECRET=

# --- External analytics (optional; Analytics → Web & marketing) ---
# PostHog: Project Settings → Personal API keys; project ID from URL
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://eu.i.posthog.com

# Google Analytics 4 + Search Console: service account JSON (single line), Viewer on GA4 property + user in GSC
GOOGLE_SERVICE_ACCOUNT_JSON=
GA4_PROPERTY_ID=
GSC_SITE_URL=https://www.example.com/

# Microsoft Clarity: Project → Settings → Data Export → API token (last 1–3 days only; 10 req/day)
CLARITY_API_TOKEN=

# Public PWA base URL for moderation / audit deep links (no trailing slash)
PWA_PUBLIC_URL=https://jobbie.sk
# JOBBIE_PUBLIC_URL=https://jobbie.sk
