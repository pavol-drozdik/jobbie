{
  "name": "jobbie-admin",
  "version": "1.0.0",
  "private": true,
  "description": "JOBBIE desktop admin panel (local only)",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:api": "npm run start:dev --prefix api",
    "dev:app": "npm run dev --prefix app",
    "dev": "concurrently -k \"npm run dev:api\" \"npm run dev:app\" \"wait-on http://127.0.0.1:5199 http://127.0.0.1:3099/health && cross-env JOBBIE_ADMIN_SKIP_API_SPAWN=1 electron .\"",
    "build:api": "npm run build --prefix api",
    "build:app": "npm run build --prefix app",
    "build:app:pack": "npm run build:api && npm run rebuild:api-native && npm run vite:env && npm run build:app",
    "clean:release": "node scripts/clean-release-run.cjs",
    "build:win": "npm run build:app:pack && node scripts/win-build.cjs",
    "build:win:unsigned": "npm run env:packaged:example && npm run build:app:pack && node scripts/win-build.cjs --unsigned",
    "build:win:release": "npm run env:packaged && npm run update:token && npm run build:app:pack && node scripts/win-build.cjs --unsigned",
    "build:mac": "npm run build:app:pack && electron-builder --mac",
    "build:mac:unsigned": "npm run env:packaged:example && npm run build:app:pack && electron-builder --mac",
    "env:packaged": "node scripts/write-packaged-env.cjs",
    "env:packaged:example": "node scripts/write-packaged-env.cjs --from-example",
    "update:token": "node scripts/write-update-token.cjs",
    "vite:env": "node scripts/write-vite-env.cjs",
    "rebuild:api-native": "node scripts/rebuild-api-native.cjs",
    "test:electron-env": "node electron/resolve-api-env.spec.cjs",
    "build:mac:release": "npm run env:packaged && npm run update:token && npm run build:app:pack && electron-builder --mac --publish never",
    "icons:generate": "node scripts/generate-icons.mjs",
    "install:all": "npm install --prefix api && npm install --prefix app",
    "build:win:force": "npm run build:app:pack && node scripts/win-build.cjs --force"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "sk.jobbie.admin",
    "productName": "JOBBIE Admin",
    "icon": "build/icon",
    "directories": {
      "output": "release",
      "buildResources": "build",
      "app": "."
    },
    "files": [
      "electron/**/*",
      "app/dist/**/*",
      "!release-build-*{,/**/*}",
      "!release-fresh{,/**/*}"
    ],
    "asarUnpack": [],
    "extraResources": [
      {
        "from": "api",
        "to": "api",
        "filter": [
          "dist/**/*",
          "package.json",
          "node_modules/**/*"
        ]
      },
      {
        "from": "api/.env.example",
        "to": "api.env.example"
      },
      {
        "from": "build/api.env",
        "to": "api.env"
      },
      {
        "from": "build/github-update-token",
        "to": "github-update-token"
      },
      {
        "from": "build/icon.ico",
        "to": "icons/icon.ico"
      },
      {
        "from": "build/icon.icns",
        "to": "icons/icon.icns"
      },
      {
        "from": "build/icon-1024.png",
        "to": "icons/icon.png"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Pr3vestTheDuck",
      "repo": "jobbie",
      "private": true,
      "releaseType": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "sign": null,
      "artifactName": "JOBBIE-Admin-${version}-Setup.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.business",
      "artifactName": "JOBBIE-Admin-${version}.${ext}",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "sign": "-",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "title": "JOBBIE Admin ${version}",
      "icon": "build/icon.icns",
      "iconSize": 96,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 200
        },
        {
          "x": 400,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JOBBIE Admin",
      "uninstallDisplayName": "JOBBIE Admin",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
