# JOBBIE Backend (NestJS) - copy to .env

# Nest API origin (no trailing slash). Stripe /thanks redirects; job-alert email "pause" links use {PUBLIC_API_URL}/api/public/job-alerts/pause
PUBLIC_API_URL=https://api.heycocreate.com

# Optional: Slovak RPO API base (default https://api.statistics.sk/rpo/v1). Used to stamp registry_verified_at on company IČO changes.
# There is no document at the base URL alone (GET /rpo/v1 → 404). Nest calls GET {base}/search?identifier=… (IČO) and ?fullName=…&onlyActive=true.
# Docs: https://susrrpo.docs.apiary.io/ — public, rate-limited; heavy polling may return 429.
# RPO_API_BASE_URL=

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional read replica (currently unused by SearchService; job/profile search uses primary SUPABASE_URL).
SUPABASE_READ_URL=

# Optional: Redis — feed cache, BullMQ background jobs (search alerts queue). Omit to use in-memory cache + inline cron.
REDIS_URL=
# Production: exit on boot when Redis is required for multi-instance / Bull workers.
# REQUIRE_REDIS_IN_PRODUCTION=1

# Performance / background workers (see docs/backend-performance-implementation-summary.md)
# BULL_WORKER_CONCURRENCY=4
# JOB_ALERT_BATCH_SIZE=50
# JOB_ALERT_CONCURRENCY=3
# PROFILE_AUTH_CACHE_TTL_SEC=300
# PROFILE_AUTH_CACHE_MAX_ENTRIES=10000
# FEED_CACHE_MAX_ENTRIES=5000
# FEED_CACHE_TTL_MS=300000
# HTTP_TIMEOUT_MS=15000
# SEARCH_REINDEX_CONCURRENCY=8
# STORAGE_ASYNC_FINALIZE=false

# Postgres: use Supabase pooler (transaction mode) for high concurrency, port 6543 — see Supabase dashboard "Connection pooling".

# Stripe (publishable key is exposed to the app for in-app Payment Sheet)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Slovak VAT invoices (§ 74): Stripe Dashboard business + tax IDs required (live AND test).
# Dashboard: Settings → Business details, Tax IDs (eu_vat SK2122259634), Invoice numbering.
# Optional: comma-separated account tax ID objects (txi_...) for invoice PDF header.
# STRIPE_ACCOUNT_TAX_IDS=txi_...
# STRIPE_INVOICE_AUTOMATIC_TAX=true
# Supplier on Stripe PDF custom fields (Dodávateľ) + OR line in footer; also in-app /nastavenia/fakturacia:
# BILLING_SUPPLIER_NAME=CoCreate s. r. o.
# BILLING_SUPPLIER_ADDRESS=Ulica a sídlo\nPSČ Mesto\nSK
# BILLING_SUPPLIER_ICO=56273975
# BILLING_SUPPLIER_DIC=2122295694
# BILLING_SUPPLIER_VAT=SK2122259634
# BILLING_SUPPLIER_OR=Spoločnosť je zapísaná v Obchodnom registri Okresného súdu Žilina v oddiele Sro vložka č. 85095/L

# Stripe Dashboard → Webhooks: send at least checkout.session.completed, payment_intent.succeeded,
# payment_intent.canceled (void abandoned invoice-backed credit invoices),
# customer.subscription.(created|updated|deleted), invoice.created (SK subscription invoice template),
# invoice.paid (required for monthly subscription credits),
# invoice.payment_failed, invoice.payment_action_required,
# charge.refunded, charge.dispute.(created|closed).
#
# Recurring subscriptions: create monthly EUR Prices in Stripe and set
# public.subscription_plans.stripe_price_id for slugs start, plus, pro, agentura (per environment).
# Optional fallback if DB columns are empty (local sk_test + prod Supabase — see docs/stripe-sandbox-catalog.md):
# STRIPE_PRICE_ID_SUBSCRIPTION_START=price_...
# STRIPE_PRICE_ID_SUBSCRIPTION_PLUS=price_...
# STRIPE_PRICE_ID_SUBSCRIPTION_PRO=price_...
# STRIPE_PRICE_ID_SUBSCRIPTION_AGENTURA=price_...
# Legacy env names (basic/standard/premium) still map to start/plus/pro.
# Sandbox example IDs (test mode): docs/stripe-sandbox-catalog.md
# Subscription free trial: set on each Stripe Price via metadata `trial_period_days` or `jobbie_trial_days`
# (Dashboard → Price → Metadata). Optional fallback for dev/UI when Prices have no trial yet:
# SUBSCRIPTION_TRIAL_FALLBACK_PERIOD_DAYS=30

# Credits: set public.credit_packs.stripe_price_id per slug (starter, popular, value, firmy).
# See supabase/scripts/stripe-catalog-price-ids.sql.template and docs/payments-credits.md.
# Fallback only when no active pack has a valid stripe_price_id (or table is empty):
STRIPE_PRODUCT_ID_CREDITS=prod_credits_default
STRIPE_PRICE_ID_CREDITS=price_credits_default
STRIPE_CREDITS_PER_PACK=10

# Optional: Cloudflare Turnstile (captcha verify at POST /api/auth/captcha/verify)
TURNSTILE_SECRET_KEY=

# Chat: AES-256-GCM at rest for chat_messages.content (32-byte key, base64-encoded).
# Generate: openssl rand -base64 32
# Rotation: see docs/database-operations-runbook.md (re-encryption required).
# REQUIRED in production — Nest boot will throw without it. In development this
# may be empty and chat bodies are stored as plaintext.
CHAT_CONTENT_ENCRYPTION_KEY=

# Typesense (primary search engine)
# TYPESENSE_API_KEY must match the server exactly (Typesense --api-key or TYPESENSE_API_KEY in docker).
# If unset or wrong, search still works via Supabase fallback.
TYPESENSE_PROTOCOL=http
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=xyz
TYPESENSE_COLLECTION_JOBS=jobs
TYPESENSE_COLLECTION_PROFILES=profiles
TYPESENSE_COLLECTION_SCHOOLS=sk_schools
# CV school picker (sk_education_institutions). Backfill: npm run search:reindex -- --schools-only
TYPESENSE_SCHOOLS_NUM_TYPOS=2
# Built-in embedding model (collection schema). Recreate collection + reindex after changing.
# Alternatives depend on your Typesense version (e.g. multilingual models for better SK paraphrase).
TYPESENSE_JOBS_EMBED_MODEL=ts/all-MiniLM-L12-v2
# Typed search: hybrid fusion; multi-token queries with lexical hits skip the embedding-only tail (see SEMANTIC_TAIL).
# Synonyms on startup: sk-vyklad, sk-kamion.
# drop_tokens_threshold 0 = do not broaden the query by dropping tokens.
TYPESENSE_JOBS_NUM_TYPOS=1
TYPESENSE_JOBS_DROP_TOKENS_THRESHOLD=0
# Hybrid weights (title,description,location,location_address,requirements,embedding): default 5,3,2,2,3,4.
# Keyword weights (title,description,location,location_address,requirements): default 7,3,2,2,2.
# Keep hits within this fraction of the best lexical text_match (default 0.52). Set off/0/false to disable ratio filter.
# TYPESENSE_JOBS_KEEP_TEXT_MATCH_RATIO=0.52
# When every hit is embedding-only (no lexical score), cap result count (default 12).
# TYPESENSE_JOBS_SEMANTIC_ONLY_MAX_HITS=12
# Default: no results if nothing matched lexically (avoids nonsense queries returning random vectors). true = allow embedding-only matches.
# TYPESENSE_JOBS_ALLOW_SEMANTIC_WITHOUT_LEXICAL=false
# Embedding-only tail: used when there are no lexical hits; skipped whenever at least one lexical hit is kept.
# Default 18 (short single-token queries use ≤6). Set 0 to disable the tail where it still applies.
# TYPESENSE_JOBS_SEMANTIC_TAIL_MAX_HITS=18
# Newsletter (POST /api/subscribe → Supabase `subscribers` + MailerLite). Optional group id for segmentation.
MAILERLITE_API_KEY=
# MAILERLITE_GROUP_ID=

# Transactional email (job/search alerts, notifications, applicant auto-replies). Cron runs every 15m when Typesense + SMTP are set.
SMTP_HOST=
SMTP_PORT=587
# true for SMTPS (465); false for STARTTLS (587). Omit to infer from port (465 → secure).
SMTP_SECURE=
SMTP_USER=
# Use single quotes when the password contains $ # spaces or braces, e.g. SMTP_PASS='p@ss{{word'
SMTP_PASS=
SMTP_FROM=Jobbie <noreply@example.com>
# Send paid Stripe faktúra PDFs after credit/subscription checkout (default on when SMTP is set)
# BILLING_INVOICE_EMAIL_ENABLED=false
# Optional: verify SMTP on Nest boot (logs warning if auth/connection fails). Useful in dev.
# SMTP_VERIFY_ON_BOOT=true
# Local dev catcher (Mailpit): SMTP_HOST=localhost SMTP_PORT=1025 SMTP_SECURE=false (leave USER/PASS empty)
# PWA origin for email deep links: unsubscribe, manage hub, post-pause redirect (no trailing slash)
# PWA origin for email links and SEO canonicals (align with NUXT_PUBLIC_SITE_URL)
PUBLIC_APP_URL=https://jobbie.sk
# IndexNow (Bing/Yandex) — same UUID as NUXT_PUBLIC_INDEXNOW_KEY; pings on job/ad publish
INDEXNOW_KEY=

# Optional: search analytics
SEARCH_ANALYTICS_SECRET=

# Sentry (NestJS / Node). Leave unset to disable error reporting.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Comma-separated browser origins. Required when NODE_ENV=production (API will not start without it).
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# BFF session cookies (HttpOnly).
# NOTE: SESSION_COOKIE_SECRET was previously documented here but is no longer
# read by the backend. `jb_at` carries a Supabase-signed JWT (integrity via
# signature). `jb_sid` is bound to a row in `api_user_sessions` and validated
# server-side on every request (see SessionRevocationService). Cookies are
# NOT cookie-parser-signed; if you want to add that protection in future, also
# update `main.ts` to pass the secret to `cookieParser(...)`.
# SESSION_COOKIE_DOMAIN=.jobbie.sk
# Should be >= Supabase Auth JWT expiry (Dashboard). Too low causes frequent refresh/logout.
SESSION_ACCESS_TTL_SECONDS=3600
SESSION_REFRESH_TTL_DAYS=30
# Used to refresh Supabase tokens server-side (public anon key)
SUPABASE_ANON_KEY=

# JWT verification (defaults: iss = $SUPABASE_URL/auth/v1, aud = authenticated)
# ES256/RS256 via JWKS by default — Supabase projects on asymmetric keys.
# SUPABASE_JWT_ISSUER=
# SUPABASE_JWT_AUDIENCE=authenticated
# Legacy HS256 acceptance is OFF by default. ONLY enable when the Supabase
# project is on a symmetric JWT secret. Leaving this off prevents algorithm
# confusion if the shared HS256 secret ever leaks.
# SUPABASE_JWT_ALLOW_HS256=false
# SUPABASE_JWT_SECRET=

# GET /debug/supabase-project: requires this header value in EVERY environment
# (used to be open in non-production — closed 2026-06 audit).
# DEBUG_SUPABASE_PROJECT_SECRET=

# File upload AV scanning (ClamAV INSTREAM over TCP). Leave CLAMAV_HOST unset
# to disable. In production, set CLAMAV_FAIL_OPEN=false to reject uploads when
# the scanner is unreachable; otherwise scan failures are logged and skipped.
# CLAMAV_HOST=clamd
# CLAMAV_PORT=3310
# CLAMAV_TIMEOUT_MS=10000
# CLAMAV_MAX_BYTES=26214400
# CLAMAV_FAIL_OPEN — when unset: false in production (fail-closed), true in dev.
# CLAMAV_FAIL_OPEN=false

# Prometheus scrape at GET /metrics (no /api prefix). REQUIRED in every
# environment — send `Authorization: Bearer <token>` from your scraper. Set to
# a long random string. Without it the endpoint returns 503.
METRICS_BEARER_TOKEN=

# Audit / compliance (HMAC chain; set a long random string in production)
AUDIT_CHAIN_SECRET=
# API request log sampling 0..1 (default 0.02)
AUDIT_API_SAMPLE_RATE=0.02
AUDIT_RETENTION_TELEMETRY_DAYS=90
AUDIT_RETENTION_FINANCIAL_YEARS=7
# job_impressions feed penalty + row purge (default 90)
ENGAGEMENT_RETENTION_DAYS=90

# Maintenance crons (device sessions, storage orphan grace)
MAINTENANCE_DEVICE_SESSION_DAYS=90
MAINTENANCE_STORAGE_ORPHAN_GRACE_DAYS=7

# Web Push (VAPID). Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto: or https: URL identifying the sender (web-push requirement)
VAPID_SUBJECT=mailto:ahoj@jobbie.sk

# Sales inquiries from /cennik addon services contact form
PRICING_INQUIRY_TO=ahoj@jobbie.sk

# Required for signed pause/unsubscribe links in job alert emails (long random string)
NOTIFICATION_PREFERENCE_TOKEN_SECRET=
# PWA origin for deep links in emails (no trailing slash); falls back to PUBLIC_APP_URL
PUBLIC_APP_ORIGIN=

# SMS (Twilio). Leave unset to skip outbound SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15551234567

