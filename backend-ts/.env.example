# JOBBIE Backend (NestJS) - copy to .env

# Public base URL for redirects (Stripe success/cancel → /thanks page)
PUBLIC_API_URL=https://api.heycocreate.com

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe (publishable key is exposed to the app for in-app Payment Sheet)
STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_JOB_POST=price_...
# Credits: either multiple products (one pack per product) or single product with multiple prices
STRIPE_CREDIT_PRODUCT_IDS=prod_...,prod_...,prod_...
# Or single product (multiple prices) and optional default price fallback
STRIPE_PRODUCT_ID_CREDITS=prod_...
STRIPE_PRICE_ID_CREDITS=price_...

DEBUG=false
